# --- Target app login ---
# hai-neo uses Microsoft SSO + MFA, so you do NOT put credentials here.
# Instead log in once by hand:  npm run login -- --storyboard <file>
# (These are only used for simple username/password apps, if you ever point the
#  tool at one; leave blank for hai-neo.)
NEO_USERNAME=
NEO_PASSWORD=

# --- Optional: Azure models via AI SDK (only for storyboard generation + LLM-judge) ---
# Leave unset for v0: hand-author storyboards and use the automated hard-check eval.
AZURE_RESOURCE_NAME=
AZURE_API_KEY=
AZURE_DEPLOYMENT=            # e.g. your gpt-4o deployment name
AZURE_VISION_DEPLOYMENT=     # vision-capable deployment for the LLM judge (optional)

# --- Neo MCP (comprehension layer, READ-ONLY) ---
# Your platform-scoped Neo MCP endpoint. The key is usually embedded in the URL
# path (e.g. https://<host>/mcp/<key>). Used by `explore` to inventory the org.
NEO_MCP_URL=
# Only if your endpoint expects an Authorization: Bearer header instead:
NEO_MCP_TOKEN=
# Transport: "http" (Streamable HTTP, default) or "sse". Flip to sse if http won't connect.
NEO_MCP_TRANSPORT=http

# --- Recorder ---
# CDP port used when Stagehand attaches for act()/self-heal (only when a
# storyboard uses intent/act AND Azure is configured). Change if 9222 is in use.
# STAGEHAND_CDP_PORT=9222
# HEADFUL=1                  # watch the browser while it records (default: headless)
