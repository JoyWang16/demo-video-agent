# --- Target app login (consumed by the recorder, off-camera; never logged) ---
NEO_USERNAME=you@example.com
NEO_PASSWORD=change-me

# --- Optional: Azure models via AI SDK (only for storyboard generation + LLM-judge) ---
# Leave unset for v0: hand-author storyboards and use the automated hard-check eval.
AZURE_RESOURCE_NAME=
AZURE_API_KEY=
AZURE_DEPLOYMENT=            # e.g. your gpt-4o deployment name
AZURE_VISION_DEPLOYMENT=     # vision-capable deployment for the LLM judge (optional)

# --- Recorder ---
# HEADFUL=1                  # watch the browser while it records (default: headless)
